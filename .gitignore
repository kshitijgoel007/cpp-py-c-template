# ==============================================================================
# Build artifacts
# ==============================================================================
# General build directory
build/
[Bb]uild/

# CMake specific files
CMakeFiles/
CMakeCache.txt
*.cmake
# Exclude source cmake directories from the *.cmake rule above
!cmake/
!tests/cmake/

# Python Packaging artifacts
dist/
*.egg-info/
.coverage
coverage.xml
htmlcov/

# ==============================================================================
# Compiled files and libraries
# ==============================================================================
# C/C++ object files
*.o
*.obj

# Libraries
*.a
*.lib
*.so
*.dylib
*.dll

# ==============================================================================
# Python specific
# ==============================================================================
# Byte-compiled / optimized files
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual Environments
venv/
.venv/
env/
.env
.copier-answers.yml

# ==============================================================================
# Project-specific generated files
# ==============================================================================
# Auto-generated binding and metadata
src/my_c_wrapper/_ctypes.py

# ==============================================================================
# OS and IDE files
# ==============================================================================
# OS-generated files
.DS_Store
Thumbs.db

# IDE configuration
.vscode/
.idea/
