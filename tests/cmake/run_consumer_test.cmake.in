set(prefix "@CMAKE_CURRENT_BINARY_DIR@/consumer-prefix")
set(build_dir "@CMAKE_CURRENT_BINARY_DIR@/consumer-build")

file(REMOVE_RECURSE "${prefix}" "${build_dir}")

execute_process(
    COMMAND "@CMAKE_COMMAND@" --install "@CMAKE_CURRENT_BINARY_DIR@" --prefix "${prefix}"
    RESULT_VARIABLE install_result
)
if(NOT install_result EQUAL 0)
    message(FATAL_ERROR "Project installation failed")
endif()

execute_process(
    COMMAND
        "@CMAKE_COMMAND@"
        -S "@CMAKE_CURRENT_SOURCE_DIR@/tests/consumer"
        -B "${build_dir}"
        "-DCMAKE_PREFIX_PATH=${prefix}"
        "-DCMAKE_BUILD_TYPE=Release"
        "-DCMAKE_RUNTIME_OUTPUT_DIRECTORY=${build_dir}/bin"
    RESULT_VARIABLE configure_result
)
if(NOT configure_result EQUAL 0)
    message(FATAL_ERROR "Consumer configuration failed")
endif()

execute_process(
    COMMAND "@CMAKE_COMMAND@" --build "${build_dir}" --config Release
    RESULT_VARIABLE build_result
)
if(NOT build_result EQUAL 0)
    message(FATAL_ERROR "Consumer build failed")
endif()

execute_process(
    COMMAND "${build_dir}/bin/myproject_consumer@CMAKE_EXECUTABLE_SUFFIX@"
    RESULT_VARIABLE run_result
)
if(NOT run_result EQUAL 0)
    message(FATAL_ERROR "Consumer executable failed")
endif()
